<%- include('./base/header.ejs')%>
    <div class="container">
        <div class="alert bg-success my-3">
            <h4 class="text-center text-white">Add New Book</h4>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col"></div>
            <div class="col">
                <form action="/add/book" method="post">
                    <div class="mt-1">
                        <label class="form-label">BookId:</label>
                        <input type="text" class="form-control" placeholder="Enter Book Id:" name="bookId" />
                    </div>
                    <div class="mt-1">
                        <label class="form-label">Book Name:</label>
                        <input type="text" class="form-control" placeholder="Enter Book Name:" name="bookName"  />
                    </div>
                    <div class="mt-1">
                        <label class="form-label">Price:</label>
                        <input type="number" class="form-control" placeholder="Enter Price:" name="price" />
                    </div>
                    <div class="mt-2">
                        <input type="submit" class="btn btn-success" value="Add Book">
                    </div>
                </form>
            </div>
            <div class="col"></div>
        </div>
    </div>
    <%- include('./base/footer.ejs')%>